# My ghostty configuration

font-family = "JetBrains Mono"
shell-integration = zsh

# create splits
keybind = ctrl+]=new_split:right
keybind = ctrl+[=new_split:up

# tabs
keybind = ctrl+t=new_tab
keybind = ctrl+w=close_tab

# navigate splits
keybind = ctrl+up=goto_split:up
keybind = ctrl+down=goto_split:down
keybind = ctrl+right=goto_split:right
keybind = ctrl+left=goto_split:left

